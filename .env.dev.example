# Database
POSTGRES_DB=crm_database
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# RabbitMQ / Celery / Redis
RABBITMQ_DEFAULT_USER=crm_user
RABBITMQ_DEFAULT_PASS=change_me
REDIS_PASSWORD=change_me
FLOWER_BASIC_AUTH=admin:flower

CELERY_WORKER_CONCURRENCY=1

# Django
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Mail runtime
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_TIMEOUT=20

# Azure Key Vault
SECRET_STORE_BACKEND=azure_key_vault
AZURE_KEY_VAULT_URL=https://example-key-vault-dev.vault.azure.net/
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=11111111-1111-1111-1111-111111111111
AZURE_CLIENT_SECRET=example-dev-client-secret
AZURE_MANAGED_IDENTITY_CLIENT_ID=
