# Database
DB_NAME=crm_database
DB_USER=crm_user
DB_PASSWORD=change_me
DB_HOST=db
DB_PORT=5432

# RabbitMQ / Celery / Redis
RABBITMQ_DEFAULT_USER=crm_user
RABBITMQ_DEFAULT_PASS=change_me
CELERY_BROKER_URL=amqp://crm_user:change_me@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:change_me@redis:6379/1
REDIS_PASSWORD=change_me
DJANGO_CACHE_URL=redis://:change_me@redis:6379/2
CELERY_WORKER_CONCURRENCY=1
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:flower

# Mail runtime
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_TIMEOUT=20
#MAIL_CONFIG_TEST_SESSION_TTL_SECONDS=600

# Django
DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False



# Azure Key Vault
SECRET_STORE_BACKEND=azure_key_vault
AZURE_KEY_VAULT_URL=https://example-key-vault-dev.vault.azure.net/
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=11111111-1111-1111-1111-111111111111
AZURE_CLIENT_SECRET=example-dev-client-secret
AZURE_MANAGED_IDENTITY_CLIENT_ID=
