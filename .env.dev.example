DB_NAME=crm_database
DB_USER=crm_user
DB_PASSWORD=change_me
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://user:pass@db:5432/dbname

#DB Container bilgileri
POSTGRES_DB=crm_database
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=123456


# Celery / RabbitMQ / Redis
RABBITMQ_DEFAULT_USER=crm_user
RABBITMQ_DEFAULT_PASS=rabbitmq
CELERY_BROKER_URL=amqp://crm_user:change_me@rabbitmq:5672//
REDIS_PASSWORD=redis
CELERY_RESULT_BACKEND=redis://:change_me@redis:6379/1
CELERY_WORKER_CONCURRENCY=2

# Mail config
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=your@email.com
EMAIL_TIMEOUT=10

DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=dev.melcrm.com,www.dev.melcrm.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://dev.melcrm.com
CSRF_TRUSTED_ORIGINS=https://dev.melcrm.com
DJANGO_CACHE_URL=redis://:change_me@redis:6379/2

VITE_API_BASE_URL=https://dev.melcrm.com/api

DJANGO_SECURE_SSL_REDIRECT=True
