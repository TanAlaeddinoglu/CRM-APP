# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

cat >> .gitignore <<'EOF'

# local env files
.env
.env.*
db.env
db.env.*
docker/.env
docker/.env.*

# keep examples tracked
!.env.example
!.env.*.example
!db.env.example
!db.env.*.example
EOF
