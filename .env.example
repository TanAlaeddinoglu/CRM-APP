# =========================================================
# LOCAL DEVELOPMENT
# =========================================================
# Copy the values you need into your real `.env` file.
# This file documents both local and production-style variables
# in one place.

# Secret store
SECRET_STORE_BACKEND=env

# Database
POSTGRES_DB=crm_database
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# RabbitMQ / Celery / Redis
RABBITMQ_DEFAULT_USER=crm_user
RABBITMQ_DEFAULT_PASS=change_me
CELERY_BROKER_URL=amqp://crm_user:change_me@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:change_me@redis:6379/1
REDIS_PASSWORD=change_me
DJANGO_CACHE_URL=redis://:change_me@redis:6379/2
CELERY_WORKER_CONCURRENCY=1
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:change_me

# Django
DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# Mail runtime
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_TIMEOUT=100
MAIL_CONFIG_TEST_SESSION_TTL_SECONDS=600
DEFAULT_FROM_EMAIL=noreply@example.com

# Local SMTP secret examples
# Important: mail credentials are resolved by secret name from the MailConfiguration
# record in the database. With SECRET_STORE_BACKEND=env, those secret names must
# exist as environment variables.
#
# Example only:
# If the active MailConfiguration.username_secret_name is `local-smtp-username`
# and password_secret_name is `local-smtp-password`, then define:
local-smtp-username=mailer@example.com
local-smtp-password=change_me

# Azure Key Vault
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MANAGED_IDENTITY_CLIENT_ID=


# =========================================================
# PRODUCTION
# =========================================================
# Production secrets should come from Azure Key Vault.
# Do not place real production secrets into `.env`.

# Secret store
# Use `azure_key_vault` in production.
SECRET_STORE_BACKEND=azure_key_vault

# Database
# These are kept here because database connection values may be read from
# environment as well as from deployment/runtime configuration.
POSTGRES_DB=crm_database
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# RabbitMQ / Celery / Redis
# Leave secret values empty here. They should come from Azure Key Vault.
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_PASSWORD=
DJANGO_CACHE_URL=
CELERY_WORKER_CONCURRENCY=1
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Mail runtime
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_TIMEOUT=100

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-key-vault-name.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MANAGED_IDENTITY_CLIENT_ID=
