DB_NAME=crm_database
DB_USER=crm_user
DB_PASSWORD=123456
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://user:pass@db:5432/dbname

# Celery / RabbitMQ / Redis
RABBITMQ_DEFAULT_USER=crm_user
RABBITMQ_DEFAULT_PASS=change_me
CELERY_BROKER_URL=amqp://crm_user:change_me@rabbitmq:5672//
REDIS_PASSWORD=change_me
CELERY_RESULT_BACKEND=redis://:change_me@redis:6379/1
CELERY_WORKER_CONCURRENCY=2
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:change_me

#MAIL CONFIG
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=your@email.com
EMAIL_TIMEOUT=10

DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=False

DJANGO_ALLOWED_HOSTS=melcrm.com,www.melcrm.com
CORS_ALLOWED_ORIGINS=https://melcrm.com
CSRF_TRUSTED_ORIGINS=https://melcrm.com

VITE_API_BASE_URL=https://melcrm.com/api
